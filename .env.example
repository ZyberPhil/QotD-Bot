# ── Discord ────────────────────────────────────────────────────────────────────
# Bot token from the Discord Developer Portal → Bot → Token
DISCORD_TOKEN=your_bot_token_here

# Right-click your server in Discord (Developer Mode must be on) → Copy Server ID
DISCORD_GUILD_ID=123456789012345678

# Right-click the #question-of-the-day channel → Copy Channel ID
DISCORD_CHANNEL_ID=123456789012345678

# ── Scheduling ─────────────────────────────────────────────────────────────────
# Time of day in HH:mm format interpreted in the configured timezone
POST_TIME=07:00

# IANA timezone name (must match a timezone available in the container)
TIMEZONE=Europe/Berlin

# ── Database ───────────────────────────────────────────────────────────────────
# PostgreSQL password (used by both the db service and the connection string)
POSTGRES_PASSWORD=change_me_to_a_strong_password
